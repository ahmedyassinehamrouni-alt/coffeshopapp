rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function getStaff() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getStaff().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isStaff() {
      return isAuthenticated() && getStaff().isActive == true;
    }

    function isCashierOrAdmin() {
      return isAuthenticated() &&
        (getStaff().role == 'admin' || getStaff().role == 'cashier');
    }

    // ── Staff ───────────────────────────────────────────────────────────────
    // Staff can read their own doc; admin can read/write all staff docs
    match /staff/{staffId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == staffId || isAdmin());
      allow write: if isAdmin();
    }

    // ── Tables ──────────────────────────────────────────────────────────────
    // All active staff can read; only admin can create/delete; staff can update status
    match /tables/{tableId} {
      allow read: if isStaff();
      allow create, delete: if isAdmin();
      allow update: if isStaff();
    }

    // ── Menu Items ──────────────────────────────────────────────────────────
    // All active staff can read; only admin can write
    match /menuItems/{itemId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ── Orders ──────────────────────────────────────────────────────────────
    // All active staff can read and create; only admin can delete
    match /orders/{orderId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ── Payments ────────────────────────────────────────────────────────────
    // Cashiers and admins can create/update; all staff can read
    match /payments/{paymentId} {
      allow read: if isStaff();
      allow create, update: if isCashierOrAdmin();
      allow delete: if isAdmin();
    }
  }
}
